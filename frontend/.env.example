VITE_API_URL=http://localhost:4000/api

# URL pública de la app (para links en WhatsApp/Email)
# En desarrollo: dejar vacío (usa localhost automáticamente)
# En producción: poner la URL real, ej: https://erp.mamkam.cl
VITE_PUBLIC_URL=

# ── Google Sheets como base de datos ─────────────────────────────────
# Pasos para activar:
# 1. Crea un Google Sheet en blanco
# 2. Abre: Extensiones → Apps Script
# 3. Pega el contenido de frontend/google-sheets/Code.gs
# 4. Ejecuta la función "setupSheet" una vez (crea las hojas automáticamente)
# 5. Despliega como Web App:
#    Implementar → Nueva implementación → Aplicación web
#    - Ejecutar como: Yo (propietario)
#    - Acceso: Cualquier usuario
# 6. Copia la URL de la web app aquí:
VITE_SHEETS_API_URL=https://script.google.com/macros/s/TU_SCRIPT_ID/exec

# EmailJS — https://www.emailjs.com (gratis hasta 200 emails/mes)
# 1. Crea cuenta en emailjs.com
# 2. Conecta tu servicio de correo (Gmail, Outlook, etc.)
# 3. Crea una plantilla con variables: to_email, to_name, numero, fecha,
#    direccion, items_table, neto, iva, total, observaciones
# 4. Copia los IDs aquí
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx
